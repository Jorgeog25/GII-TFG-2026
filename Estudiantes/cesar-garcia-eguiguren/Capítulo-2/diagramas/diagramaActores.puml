@startuml DiagramaActores
!theme plain
left to right direction
skinparam shadowing false
skinparam roundcorner 15
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam NoteBackgroundColor #323b57
skinparam actor {
  BackgroundColor #4B3FA6
  BorderColor #E2E8F5
  FontColor #E2E8F5
}
skinparam ArrowColor #38BDF8
skinparam rectangle {
  BorderColor #2A3850
  FontColor #E2E8F5
}

actor "Director\nDatos globales sin filtro\n\n21 CU disponibles" as Director #4B3FA6

actor "Responsable\nScope inyectado en JWT:\nemployee_ids\ndepartment_ids\nproject_ids\n\n18 CU disponibles" as Responsable #1F7A63

rectangle "Netkia Analytics\nMódulo externo sobre Odoo v16" as System #141824 {

  rectangle "P1 · Iniciar Sesión · Cerrar Sesion" as P1 #BB3A29

  rectangle "P2–P5 · Entidades operativas (CU-02..CU-09)\nEmpleados · Departamentos · Proyectos · Tareas" as P2 #927410

  rectangle "P6 · Análisis (CU-10, CU-11, CU-12, CU-21)\nMétricas · Gráficos analíticos\nAsistencia vs imputaciones · Carga de trabajo de equipo" as P7 #927410

  rectangle "P7 · Rentabilidad (CU-13, CU-14)\n★ Exclusivo Director · 403 para Responsable\nCU-14 unifica líneas de proyecto y de cliente" as P8 #4B3FA6

  rectangle "P8 · Utilidades (CU-15)\nBúsqueda global" as P9 #927410

  rectangle "P9 · Snapshots (CU-17..CU-20)\nGuardar (upsert diario) · Listar\nDetalle · Eliminar" as P10 #3A6A8A

}

actor "Odoo v16 ERP\n(PostgreSQL · solo lectura)\n\nhr_employee · res_users\nproject_project · hr_department\nproject_task · hr_attendance\naccount_analytic_line" as Odoo #555555

actor "MongoDB\n(lectura/escritura)\n\nmetric_snapshots\nchart_snapshots\nentity_snapshots\n\n1 snapshot por\n(tipo, params, día)" as Mongo #2F6F3F

Director --> P1
Responsable --> P1

P1 --> P2
P1 --> P8
P1 --> P9
P1 --> P10

P2 --> Odoo
P7 --> Odoo
P8 --> Odoo
P9 --> Odoo

P10 --> Mongo
P7 ..> P10 : "Guardar snapshot"
P8 ..> P10 : "Guardar snapshot"
P2 ..> P10 : "Guardar snapshot"


note right of System
  **Dos frontends** comparten este backend único
  y el mismo esquema JWT:
  · **Frontend principal** (puerto 3000): calcula
    en tiempo real sobre Odoo y permite guardar
    snapshots (CU-17) desde cada vista calculada.
  · **Visor de snapshots · frontend2** (puerto 3001):
    solo consume MongoDB — lista, visualiza y
    elimina snapshots (CU-18, CU-19, CU-20).
end note

@enduml
