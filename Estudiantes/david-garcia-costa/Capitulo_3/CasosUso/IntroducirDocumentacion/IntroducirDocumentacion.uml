@startuml
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

title CU-01 - Introducir documentación funcional

package "Vista" {
  class DocumentationView
}

package "Controlador" {
  class DocumentationController
}

package "Modelo" {
  class Documentation
  class Session
}

DocumentationView --> DocumentationController : POST /api/documentation
DocumentationController --> Documentation : crear documento funcional
DocumentationController --> Session : asociar a sesión

@enduml
