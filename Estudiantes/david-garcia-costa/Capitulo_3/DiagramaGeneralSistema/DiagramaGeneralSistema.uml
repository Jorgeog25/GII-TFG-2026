@startuml
skinparam packageStyle rectangle
skinparam shadowing false

title Diagrama general del sistema

actor Usuario

frame "kiwi-mvc\nNode.js + Express" {
  frame "Vista SPA" {
    component "index.html" as IndexHtml
    component "app.js" as AppJs
    component "app.css" as AppCss
  }

  frame "Backend MVC" {
    component Routes
    component AuthMiddleware
    component Controllers
    component Services
    component Models
  }
}

database "MongoDB\nkiwi_mvc_manual" as MongoDB

frame "Agent_ApiKiwi\nFastAPI + Google ADK" {
  component HandoffEndpoint
  component KiwiOrchestrator
  component DraftPipelineAgent
  component ExtractUcRfAgent
  component KiwiGherkinAgent
  component ReviewPublishAgent
  component DraftStoreJSON
  database "SQLite\nsessions.db" as SQLite
}

cloud "OpenAI / LiteLLM" as LLM
cloud "Kiwi TCMS\nXML-RPC API" as Kiwi
database "MariaDB\nKiwi TCMS" as MariaDB

Usuario --> IndexHtml
IndexHtml --> AppJs
AppJs --> Routes : fetch REST JSON

Routes --> AuthMiddleware
AuthMiddleware --> Controllers
Controllers --> Services
Controllers --> Models
Models --> MongoDB

Controllers --> HandoffEndpoint : handoff automático
HandoffEndpoint --> KiwiOrchestrator
KiwiOrchestrator --> MongoDB : leer documentations
KiwiOrchestrator --> DraftPipelineAgent
DraftPipelineAgent --> ExtractUcRfAgent
DraftPipelineAgent --> KiwiGherkinAgent
ExtractUcRfAgent --> LLM
KiwiGherkinAgent --> LLM
ReviewPublishAgent --> DraftStoreJSON
KiwiOrchestrator --> SQLite

Services --> Kiwi : publicar manual
ReviewPublishAgent --> Kiwi : publicar automático
Kiwi --> MariaDB

@enduml
